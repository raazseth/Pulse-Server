{
  "name": "pulse-hud",
  "version": "1.0.0",
  "description": "Standalone backend for the Pulse HUD real-time interview system",
  "main": "dist/cmd/api/main.js",
  "scripts": {
    "build": "tsc && tsc-alias",
    "dev": "cross-env NODE_ENV=development nodemon ./cmd/api/main.ts",
    "dev:local": "cross-env NODE_ENV=development node ./cmd/api/main.ts",
    "test": "cross-env NODE_ENV=test vitest run",
    "test:watch": "cross-env NODE_ENV=test vitest",
    "test:coverage": "cross-env NODE_ENV=test vitest run --coverage",
    "prod": "npm run build && cross-env NODE_ENV=production node ./dist/cmd/api/main.js",
    "start": "node ./dist/cmd/api/main.js",
    "migration": "node ./migrations/run.js",
    "generate": "npm run migration"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/cors": "^2.8.19",
    "@types/dotenv": "^6.1.1",
    "@types/express": "^5.0.6",
    "@types/helmet": "^0.0.48",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.3.1",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.1.5",
    "cross-env": "^7.0.3",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@xenova/transformers": "^2.17.1",
    "cookie-parser": "^1.4.7",
    "ffmpeg-static": "^5.2.0",
    "fluent-ffmpeg": "^2.1.3",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "openai": "^6.34.0",
    "pg": "^8.20.0",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  }
}
