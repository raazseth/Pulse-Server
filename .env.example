# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000

# ── Database (required) ───────────────────────────────────────────────────────
# Local:      postgresql://user:password@localhost:5432/pulse_hud
# Cloud SQL:  postgresql://user:password@/pulse_hud?host=/cloudsql/PROJECT:REGION:INSTANCE
DATABASE_URL=postgresql://user:password@localhost:5432/pulse_hud

# ── JWT Secrets (required in production) ─────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-me-in-production
JWT_REFRESH_SECRET=change-me-in-production

# ── AI Provider (optional) ────────────────────────────────────────────────────
# Used for HUD prompt suggestions only (NOT transcription — see Whisper below).
# Primary SDK: OpenAI Chat Completions (ChatGPT-class models). Set OPENAI_API_KEY to enable.
# If OPENAI_API_KEY is set, OpenAI is used regardless of AI_PROVIDER=gemini.
# Omit both API keys to use the built-in rule-based fallback.
# AI_PROVIDER=openai    → OpenAI only (requires OPENAI_API_KEY; fails fast if missing)
# AI_PROVIDER=gemini    → Gemini only when OPENAI_API_KEY is unset (requires GEMINI_API_KEY)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# GEMINI_API_KEY=AIza...

# ── Local Whisper (self-hosted transcription — no API key required) ────────────
# Model variant: tiny.en | base.en | small.en | medium.en | large-v3
# base.en is a good default (~74 MB, ~1s/chunk on CPU)
WHISPER_MODEL=base.en
WHISPER_LANGUAGE=en
# Directory where ONNX model files are cached. Created automatically if missing.
WHISPER_MODELS_DIR=./models

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated exact origins (production domain, custom *.vercel.app names, etc.).
# Defaults: localhost / 127.0.0.1 dev ports only.
# ALLOWED_ORIGINS=https://pulse-web-sigma.vercel.app,https://your-custom-domain.com
#
# Vercel preview / git deploy URLs look like https://project-hash-TEAM.vercel.app
# Set TEAM to your Vercel team slug so all those origins are allowed without listing each deploy:
# CORS_VERCEL_TEAM_SUFFIX=rajs-projects-ab8ef4bc

# ── WebSocket ─────────────────────────────────────────────────────────────────
# HUD_WS_PATH=/ws/transcript
